# ==== Server ====
PORT=10000
NODE_ENV=production

# ==== Frontend domain (Netlify) - dùng cho CORS whitelist ====
# Có thể liệt kê nhiều domain, phân cách bằng dấu phẩy
FRONTEND_ORIGIN=https://your-app.netlify.app,http://localhost:5173

# ==== Teacher Auth ====
# Mật khẩu đơn giản cho giáo viên đăng nhập vào Teacher Dashboard
TEACHER_PASSWORD=doi-mat-khau-nay-thanh-mat-khau-that-manh

# ==== Supabase ====
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Dùng Service Role Key (KHÔNG dùng anon key) vì server cần quyền ghi/đọc đầy đủ, bỏ qua RLS một cách có kiểm soát
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==== JWT ====
JWT_SECRET=doi-chuoi-nay-thanh-mot-secret-that-manh
JWT_EXPIRES_IN=7d

# ==== Gemini AI ====
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash

# ==== Business rules ====
PASS_THRESHOLD_PERCENT=80
